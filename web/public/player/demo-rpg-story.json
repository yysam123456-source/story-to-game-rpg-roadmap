      ]
    },
    {
      "id": "inner_gate",
      "type": "narrative",
      "chapter": "第一章 · 内门之路",
      "text": "测灵石光芒大作，老者眼中闪过一丝惊讶。\n\n\"不错，资质尚可。从今日起，你便是我青云宗的外门弟子。\"\n\n你恭敬地接过弟子令牌，感受到上面流转的灵气。修仙之路，正式开启。",
      "choices": [
        {
          "text": "前往藏经阁挑选功法",
          "weight": "branch",
          "changes": {
            "cultivation": 2,
            "show": true
          },
          "next": "end_chapter1"
        },
        {
          "text": "先去弟子居所安顿",
          "weight": "minor",
          "changes": {
            "mind": 3,
            "hp": 10,
            "show": true
          },
          "next": "end_chapter1"
        }
      ]

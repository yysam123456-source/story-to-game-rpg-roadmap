              "duration": 2500
            }
          }
        }
      ]
    },
    {
      "id": "node_11虽败犹荣",
      "chapter": "第四章 · 内门考核",
      "type": "narrative",
      "text": "你躺在地上，仰望天空。体内灵力几近枯竭，但你的眼神没有一丝放弃。\n\n「不……还不行……」你挣扎着想要站起来，但身体已经不听使唤。\n\n陈长老走过来。他看着你的眼神，沉默了很久。\n\n然后他转向其他考官：「林渊，内门考核——通过。」\n\n全场哗然。赵天阳愤怒地质问为什么，但陈长老只说了一句：「他输了比试，但赢了心性。修仙之路，心性为先。」",
      "choices": [
        {
          "id": "ch_grateful",
          "text": "感恩陈长老的认可，努力变强",
          "next": "node_12内门弟子",
          "changes": {
            "realm": 1,
            "mind": 10,
            "cultivation": 5,
            "show": true,
            "feedback": {
              "style": "toast",
              "duration": 2500
            }
          },
          "affinityChanges": [
            {
              "npcId": "elder_chen",
              "delta": 25
            }
          ]
        }
      ]
    },
    {
      "id": "node_12内门弟子",
      "chapter": "第五章 · 前路漫漫",
      "type": "narrative",
      "text": "你正式成为青炉宗内门弟子。陈长老将你收为亲传弟子，亲自指导你的修炼。\n\n在陈长老的指导下，你的进步速度远超同辈。你一边修炼，一边继续研究铁片上的剑阵。\n\n铁片中的剑意种子在你心中生根发芽。你知道，终有一天，你会完全解封这柄仙剑——\n\n但现在，你只需要一步一步走下去。\n\n修仙之路，始于足下。\n\n——青炉夜火 · 序章 完——",
      "choices": [
        {
          "id": "ch_continue",
          "text": "继续你的修仙之旅……",
          "next": "ending_ordinary",
          "changes": {
            "cultivation": 20,
            "swordIntent": 5,
            "show": true,
            "feedback": {
              "style": "toast",
              "duration": 2500
            }
          }
        }
      ]
    },
    {
      "id": "ending_ordinary",
      "chapter": "尾声",
      "type": "ending",
      "text": "你带着铁片离开了青炉峰。铁片偶尔会发出微弱的金色光芒，但你始终无法理解它的含义。\n\n多年后，你在一个小村庄安了家，成为一名采药人。偶尔会在月光下取出铁片端详，想起那个关于修仙的梦。\n\n铁片上的剑痕依然明亮，但你已经不再期待什么了。\n\n也许在另一个平行世界里，你做出了不同的选择。\n\n——结局：平凡一生——",
      "choices": []
    }
